{
  "realm": "payflow",
  "displayName": "PayFlow",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 300,
  "clientScopes": [
    {
      "name": "orders:read",
      "description": "Read access to orders",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "orders:write",
      "description": "Write access to orders",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "payflow-app",
      "name": "PayFlow Application",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "payflow-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "orders:read",
        "orders:write"
      ],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "testuser",
      "email": "testuser@payflow.local",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "testuser123",
          "temporary": false
        }
      ]
    }
  ]
}
